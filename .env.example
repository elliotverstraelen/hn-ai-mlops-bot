# OpenAI — tweet generation & quality scoring
OPENAI_API_KEY=sk-proj-...

# Twitter / X API v2 — posting tweets
TWITTER_BEARER_TOKEN=AAAA...
TWITTER_API_KEY=...
TWITTER_API_SECRET=...
TWITTER_ACCESS_TOKEN=...
TWITTER_ACCESS_TOKEN_SECRET=...

# PostgreSQL — run & article logging
DATABASE_URL=postgresql://user:password@host:5432/dbname

# MLflow — experiment tracking (default: local /app/mlruns)
MLFLOW_TRACKING_URI=/app/mlruns

# Bot scheduling (default: 6 hours)
RUN_INTERVAL_SECONDS=21600
